{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/chapter_questions/**": true,
    "**/ref/**": true,
    "**/.playwright-mcp/**": true,
    "**/*.pdf": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.playwright-mcp": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/chapter_questions": true,
    "**/ref": true,
    "**/.playwright-mcp": true,
    "**/*.pdf": true,
    "**/package-lock.json": true
  },
  "typescript.tsserver.maxTsServerMemory": 2048,
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority"
  }
}
