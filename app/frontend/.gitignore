# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# DI chart/table crops: NOT committed to the repo. They are inlined into the DB as base64
# data-URIs at seed time (api/seed_di.js); this dir is just a local working copy, regenerable
# from the PDF via .varc_extract/extract_di.py.
/public/di/

# typescript
*.tsbuildinfo
next-env.d.ts
