# Required — set these in Vercel Project Settings → Environment Variables,
# and in app/frontend/.env.local for local dev.

# MongoDB connection string. Use a hosted Mongo (Atlas) for Vercel.
MONGODB_STRING=

# JWT signing key. Anything long and random.
JWT_SECRET=

# Optional. Comma-separated list of allowed origins for CORS.
# Default is http://localhost:3000. Add your prod domain if you call the API
# from another origin (you usually don't need to — Vercel serves the API on
# the same domain as the app).
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Optional. Used by the seed endpoint /api/quant-chapters/seed.
# SEED_SECRET=

# Dev-only — port for the standalone Express process (api/standalone.js).
# Used by Next.js rewrites to proxy /api/* in development.
PORT=4000
